{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "jobs-route": {
        "ClusterId": "jobs-cluster",
        "Match": {
          "Path": "/api/v1/jobs/{**catch-all}"
        }
      },
      "tenants-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/tenants/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5019"
          }
        }
      },
      "jobs-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "job-service": {
            "Address": "http://job-service:8080"
          }
        }
      }
    }
  }
}